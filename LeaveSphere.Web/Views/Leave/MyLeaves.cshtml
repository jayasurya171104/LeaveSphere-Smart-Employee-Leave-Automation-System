@model List<LeaveSphere.Web.Models.ViewModels.LeaveViewModel>
@{
    Layout = "_Layout";
    ViewData["BodyClass"] = "employee-bg";
}

<style>
    .text-muted {
        color: rgba(255, 255, 255, 0.7) !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="margin-0">My Leaves</h2>
    <a class="btn btn-primary px-4 py-2" style="border-radius: 12px;" href="/Leave/Apply">
        <i class="fas fa-plus me-2"></i> Apply New Leave
    </a>
</div>

@{
    var profile = ViewBag.Profile as dynamic;
    var balance = profile?.LeaveBalance;
}

@if (profile != null)
{
    var total = profile.LeaveBalance?.totalLeaves ?? 20;
    var used = profile.LeaveBalance?.usedLeaves ?? 0;
    var remaining = profile.LeaveBalance?.remainingLeaves ?? 20;

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="glass-item p-4 text-center">
                <div class="text-muted mb-1"><i class="fas fa-calendar-check me-2"></i> Total Entitlement</div>
                <h2 class="margin-0 text-primary">@total</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-item p-4 text-center">
                <div class="text-muted mb-1"><i class="fas fa-calendar-minus me-2"></i> Leaves Used</div>
                <h2 class="margin-0 text-danger">@used</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-item p-4 text-center">
                <div class="text-muted mb-1"><i class="fas fa-hourglass-half me-2"></i> Remaining</div>
                <h2 class="margin-0 text-success">@remaining</h2>
            </div>
        </div>
    </div>
}

@if (ViewBag.Message != null)
{
    <div class="alert alert-danger glass-item mb-4 py-2">
        <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Message
    </div>
}

<div class="glass-table shadow">
    <table class="table">
        <thead>
            <tr>
                <th><i class="far fa-calendar-alt me-2"></i> From</th>
                <th><i class="far fa-calendar-alt me-2"></i> To</th>
                <th><i class="fas fa-comment-alt me-2"></i> Reason</th>
                <th><i class="fas fa-info-circle me-2"></i> Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var leave in Model)
            {
                <tr>
                    <td>@leave.StartDate.ToShortDateString()</td>
                    <td>@leave.EndDate.ToShortDateString()</td>
                    <td style="max-width: 350px; white-space: normal; word-wrap: break-word; line-height: 1.4;">@leave.Reason</td>
                    <td>
                        @{
                            var badgeClass = leave.Status == "Approved" ? "bg-success" : 
                                            leave.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark";
                        }
                        <span class="badge @badgeClass px-3 py-2" style="border-radius: 8px;">
                            @leave.Status
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
