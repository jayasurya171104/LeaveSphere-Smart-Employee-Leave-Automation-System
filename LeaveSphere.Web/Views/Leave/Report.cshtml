@model List<LeaveSphere.Web.Models.ViewModels.LeaveViewModel>
@{
    ViewData["Title"] = "Master Leave Report";
    Layout = "_Layout";
    ViewData["BodyClass"] = "admin-bg";
}

<div class="glass-item mb-4">
    <h2 class="mb-3 text-white"><i class="fas fa-chart-line me-2 text-info"></i> Master Leave Report</h2>
    <form method="get" action="/Leave/Report" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-white-50">Department</label>
            <select name="departmentId" class="form-control">
                <option value="0">All Departments</option>
                @if (ViewBag.Departments != null)
                {
                    foreach (var dept in (List<LeaveSphere.Web.Models.ViewModels.DepartmentViewModel>)ViewBag.Departments)
                    {
                        <option value="@dept.DepartmentId" selected="@(ViewBag.CurrentDept == dept.DepartmentId ? "selected" : null)">@dept.DepartmentName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small text-white-50">Start Date</label>
            <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-white-50">End Date</label>
            <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-white-50">Status</label>
            <select name="status" class="form-control">
                <option value="">All Status</option>
                <option value="Pending" selected="@(ViewBag.CurrentStatus == "Pending" ? "selected" : null)">Pending</option>
                <option value="Approved" selected="@(ViewBag.CurrentStatus == "Approved" ? "selected" : null)">Approved</option>
                <option value="Rejected" selected="@(ViewBag.CurrentStatus == "Rejected" ? "selected" : null)">Rejected</option>
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-info flex-grow-1 shadow-sm"><i class="fas fa-search me-1"></i> Search</button>
            <a href="/Leave/Report" class="btn btn-outline-light shadow-sm"><i class="fas fa-undo"></i></a>
        </div>
    </form>
</div>

<div class="glass-table shadow">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Leave From</th>
                    <th>Leave To</th>
                    <th>Type</th>
                    <th>Reason</th>
                    <th>Status</th>
                    <th>Approved By</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var badgeClass = item.Status == "Approved" ? "bg-success" :
                                         item.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark";
                        string displayName = item.Role == "TeamLeader" ? (item.TeamLeader?.Name ?? "TL N/A") : (item.Employee?.Name ?? "Emp N/A");
                        string deptName = item.Role == "TeamLeader" ? (item.TeamLeader?.Department?.DepartmentName ?? "N/A") : (item.Employee?.Department?.DepartmentName ?? "N/A");

                        <tr>
                            <td>
                                <div class="fw-bold @(item.Role == "TeamLeader" ? "text-warning" : "text-white")">
                                    @displayName
                                    @if(item.Role == "TeamLeader") {
                                        <span class="badge bg-warning text-dark ms-1" style="font-size: 0.65rem;">TL</span>
                                    }
                                </div>
                            </td>
                            <td><span class="badge bg-light text-dark">@deptName</span></td>
                            <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                            <td><span class="text-info fw-medium">@item.LeaveType</span></td>
                            <td style="max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.Reason">@item.Reason</td>
                            <td><span class="badge @badgeClass">@item.Status</span></td>
                            <td><span class="text-white-50">@(item.ApprovedBy ?? (item.Role == "TeamLeader" ? "Admin" : "TL N/A"))</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="fas fa-folder-open fa-3x mb-3 d-block opacity-25"></i>
                            No leave records found matching your selection.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
