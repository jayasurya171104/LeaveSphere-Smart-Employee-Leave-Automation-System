@model List<LeaveSphere.Web.Models.ViewModels.LeaveReportViewModel>
@{
    Layout = "_Layout";
    ViewData["BodyClass"] = "admin-inner-bg";
    var groupedReport = Model.GroupBy(l => l.DepartmentName).ToList();
}

<div class="report-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0 text-white"><i class="fas fa-chart-pie me-2 text-info"></i> Department Wise Leave Report</h2>
        <p class="text-white-50 ms-4">Detailed day-wise view of employees on leave</p>
    </div>
    
    <div class="filter-box glass-item p-3 shadow-sm" style="border-radius: 16px;">
        <form method="get" action="/Leave/Report" class="d-flex align-items-center gap-3">
            <label class="text-white fw-bold mb-0"><i class="fas fa-calendar-day me-1"></i> Select Date:</label>
            <input type="date" name="date" class="form-control form-control-sm" 
                   value="@ViewBag.SelectedDate" 
                   style="width: 180px; background: white !important; color: #1a1a2e !important;" 
                   onchange="this.form.submit()" />
        </form>
    </div>
</div>

@if (ViewBag.Message != null)
{
    <div class="alert alert-info glass-item py-3 mb-4">
        <i class="fas fa-info-circle me-2"></i> @ViewBag.Message
    </div>
}

<div class="row">
    <div class="col-md-12">
        @if (!groupedReport.Any())
        {
            <div class="glass-item text-center py-5">
                <i class="fas fa-calendar-check fa-4x mb-3 text-info" style="opacity: 0.3;"></i>
                <h4 class="text-white">All Active!</h4>
                <p class="text-white-50">No employees are on leave for the selected date.</p>
            </div>
        }
        else
        {
            @foreach (var dept in groupedReport)
            {
                <div class="department-group mb-5">
                    <div class="dept-title-bar d-flex justify-content-between align-items-center mb-3">
                        <h4 class="text-info mb-0 fw-bold">
                            <i class="fas fa-building me-2"></i> @dept.Key
                        </h4>
                        <span class="badge bg-white text-info px-3 py-2 shadow-sm" style="border-radius: 10px; font-weight: 800;">
                            @dept.Count() Employees on Leave
                        </span>
                    </div>

                    <div class="glass-table shadow">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 30%"><i class="fas fa-user me-2"></i> Employee Name</th>
                                    <th style="width: 20%"><i class="fas fa-calendar-alt me-2"></i> Leave Date</th>
                                    <th style="width: 25%"><i class="fas fa-tag me-2"></i> Leave Type</th>
                                    <th style="width: 25%"><i class="fas fa-info-circle me-2"></i> Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in dept)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-info text-dark px-3 py-2" style="border-radius: 8px; font-weight: 700; font-size: 0.9rem;">
                                                <i class="fas fa-user-circle me-1"></i> @item.EmployeeName
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark px-3 py-2" style="border-radius: 8px; font-weight: 600;">
                                                <i class="fas fa-calendar-day me-1"></i> @item.LeaveDate.ToString("dd MMM yyyy")
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark px-3 py-2" style="border-radius: 8px; font-weight: 500; border: 1px solid #ddd;">
                                                @item.LeaveType
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge @(item.Status == "Approved" ? "bg-success" : item.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark") px-3 py-2" style="border-radius: 8px; font-weight: 600;">
                                                @item.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .dept-title-bar {
        border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 10px;
    }
    .report-header h2 {
        font-weight: 800;
        letter-spacing: -0.5px;
    }
    .filter-box:hover {
        transform: translateY(-2px);
        transition: 0.3s ease;
    }
    .glass-table {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        overflow: hidden;
    }
    .table thead th {
        background: rgba(255, 255, 255, 0.1);
        color: #0dcaf0 !important;
        border: none;
        padding: 15px 20px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }
    .table tbody td {
        padding: 15px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        vertical-align: middle;
    }
</style>
