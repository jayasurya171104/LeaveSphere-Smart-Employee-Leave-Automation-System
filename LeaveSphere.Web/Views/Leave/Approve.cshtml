@model List<LeaveSphere.Web.Models.ViewModels.LeaveViewModel>
@{
    Layout = "_Layout";
    ViewData["BodyClass"] = "admin-inner-bg";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="fas fa-check-double me-2 text-info"></i>
        @(ViewBag.Filter != null ? $"{ViewBag.Filter} Leaves" : "Approve Leaves")
    </h2>
    @if (ViewBag.Filter != null)
    {
        <a href="/Leave/Approve" class="btn btn-outline-light btn-sm shadow-sm" style="border-radius: 10px;">
            <i class="fas fa-times me-1"></i> Clear Filter
        </a>
    }
</div>

@if (ViewBag.Message != null)
{
    <div class="alert alert-danger glass-item mb-4 py-2 shadow-sm">
        <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Message
    </div>
}

<div class="glass-table shadow">
    <table class="table mb-0">
        <thead>
            <tr>
                <th><i class="fas fa-user-circle me-2"></i> Employee</th>
                <th><i class="far fa-calendar-alt me-2"></i> From</th>
                <th><i class="far fa-calendar-alt me-2"></i> To</th>
                <th><i class="fas fa-comment-alt me-2"></i> Reason</th>
                <th class="text-center"><i class="fas fa-cogs me-2"></i> Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var leave in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold fs-6">
                                @(leave.Employee?.Name ?? $"Employee #{leave.EmployeeId}")
                            </div>
                            <div class="text-muted small">
                                <i class="fas fa-building me-1"></i> @(leave.Employee?.Department?.DepartmentName ?? "N/A")
                            </div>
                        </td>
                        <td><span class="fw-medium">@leave.StartDate.ToString("dd MMM yyyy")</span></td>
                        <td><span class="fw-medium">@leave.EndDate.ToString("dd MMM yyyy")</span></td>
                        <td>
                            <div class="text-truncate" style="max-width: 250px;" title="@leave.LeaveType - @leave.Reason">
                                <span class="badge bg-dark border border-secondary text-light me-1">@leave.LeaveType</span>
                                <span style="opacity: 0.85; font-size: 0.9rem;">@leave.Reason</span>
                            </div>
                        </td>
                        <td class="text-center mt-1">
                            @if (leave.Status == "Pending")
                            {
                                <form method="post" asp-action="ApproveRequest" asp-route-id="@leave.LeaveId" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success shadow-sm me-1" style="border-radius: 8px; font-weight: 500;" title="Approve">
                                        <i class="fas fa-check"></i> Approve
                                    </button>
                                </form>
                                <form method="post" asp-action="RejectRequest" asp-route-id="@leave.LeaveId" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger shadow-sm" style="border-radius: 8px; font-weight: 500;" title="Reject">
                                        <i class="fas fa-times"></i> Reject
                                    </button>
                                </form>
                            }
                            else
                            {
                                var badgeClass = leave.Status == "Approved" ? "bg-success" :
                                                 leave.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark";
                                <span class="badge @badgeClass px-3 py-2 shadow-sm" style="border-radius: 8px; font-size: 0.85rem;">
                                    @leave.Status
                                </span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted" style="opacity: 0.7;">
                        <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                        <h5>No leave requests found.</h5>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>