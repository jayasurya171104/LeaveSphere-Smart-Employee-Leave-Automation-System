@model LeaveSphere.Web.Models.ViewModels.CreateEmployeeViewModel
@{
    Layout = "_Layout";
    ViewData["BodyClass"] = "admin-inner-bg";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="glass-item mt-5">
            <h2 class="text-center mb-4"><i class="fas fa-user-plus mr-2"></i> Create New Employee</h2>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle mr-1"></i> @ViewBag.Message
                </div>
            }

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label font-weight-bold"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter Full Name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label font-weight-bold"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter Email Address" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PasswordHash" class="form-label font-weight-bold"></label>
                    <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Enter Password" />
                    <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="DepartmentId" class="form-label font-weight-bold"></label>
                    <select asp-for="DepartmentId" class="form-control" asp-items="Model.Departments">
                        <option value="">-- Select Department --</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Role" class="form-label font-weight-bold"></label>
                    <select asp-for="Role" class="form-control">
                        <option value="Employee">Employee</option>
                        <option value="Admin">Admin</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="fas fa-check-circle"></i> Create Employee
                    </button>
                </div>
            </form>

            <div class="text-center mt-3">
                <a href="/Employee" class="btn btn-link text-white shadow-none">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>