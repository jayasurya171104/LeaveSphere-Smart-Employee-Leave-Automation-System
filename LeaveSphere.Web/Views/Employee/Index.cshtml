@model List<LeaveSphere.Web.Models.ViewModels.EmployeeViewModel>
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using Microsoft.AspNetCore.Http
@{
    Layout = "_Layout";
    ViewData["BodyClass"] = "admin-inner-bg";
    
    var tokenString = Context.Session.GetString("JWToken");
    string role = "";
    if (!string.IsNullOrEmpty(tokenString))
    {
        var handler = new JwtSecurityTokenHandler();
        var jwtSecurityToken = handler.ReadJwtToken(tokenString);
        var roleClaim = jwtSecurityToken.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role || c.Type == "role");
        role = roleClaim?.Value ?? "";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-users me-2 text-info"></i> Employees</h2>
    @if (role == "Admin")
    {
        <a class="btn btn-primary px-4 py-2 shadow-sm" style="border-radius: 12px; font-weight: 500;" href="/Employee/Create">
            <i class="fas fa-user-plus me-2"></i> Add Employee
        </a>
    }
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger glass-item mb-4 py-2">
        <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success glass-item mb-4 py-2">
        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
    </div>
}

<div class="glass-table shadow">
    <table class="table mb-0">
        <thead>
            <tr>
                <th><i class="fas fa-user-circle me-2"></i> Name</th>
                <th><i class="fas fa-envelope me-2"></i> Email</th>
                <th><i class="fas fa-building me-2 text-info"></i> Department</th>
                <th><i class="fas fa-user-shield me-2 text-primary"></i> Role</th>
                @if (role == "Admin")
                {
                    <th><i class="fas fa-cogs me-2"></i> Action</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>
                        <div class="fw-bold fs-6">@emp.Name</div>
                    </td>
                    <td><span style="opacity: 0.8;">@emp.Email</span></td>
                    <td>
                        <span class="badge bg-light text-dark px-3 py-2" style="border-radius: 8px; border: 1px solid #ddd;">
                            @(emp.Department?.DepartmentName ?? "N/A")
                        </span>
                    </td>
                    <td>
                        <span class="badge @(emp.Role == "Admin" ? "bg-primary" : "bg-dark") px-3 py-2" style="border-radius: 8px;">
                            @emp.Role
                        </span>
                    </td>
                    @if (role == "Admin")
                    {
                        <td>
                            <a href="/Employee/Edit/@emp.EmployeeId" class="btn btn-sm btn-info text-white shadow-sm me-2" style="border-radius: 8px; font-weight: 500;">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-danger shadow-sm" style="border-radius: 8px; font-weight: 500;" 
                                    onclick="openDel(@emp.EmployeeId, '@emp.Name.Replace("'", "\\'")')">
                                <i class="fas fa-trash-alt"></i> Delete
                            </button>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Delete Modal -->
<div class="del-overlay" id="delModal">
    <div class="del-box">
        <div class="del-icon"><i class="fas fa-exclamation-triangle"></i></div>
        <h4>Delete Employee?</h4>
        <p>Are you sure you want to delete <strong id="delName"></strong>?<br/>They will no longer be able to log in.</p>
        <div class="del-btns">
            <button class="btn-cancel" onclick="closeDel()">Cancel</button>
            <form id="delForm" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-confirm-del">
                    <i class="fas fa-trash-alt me-1"></i> Delete
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    /* Reuse the same premium modal styles from Department Index */
    .del-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 9999; justify-content: center; align-items: center; }
    .del-overlay.active { display: flex; }
    .del-box { background: #ffffff; border-radius: 20px; padding: 36px; text-align: center; max-width: 400px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.25); }
    .del-box .del-icon { width: 64px; height: 64px; background: #fde8ea; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px; }
    .del-box .del-icon i { font-size: 1.6rem; color: #dc3545; }
    .del-box h4 { font-size: 1.2rem; font-weight: 800; color: #1a1a2e; margin-bottom: 8px; }
    .del-box p { color: #666; font-size: 0.95rem; margin-bottom: 24px; }
    .del-box .del-btns { display: flex; gap: 12px; justify-content: center; }
    .del-box .btn-cancel { padding: 10px 28px; border-radius: 10px; background: #f0f0f0; color: #333; border: 2px solid #ddd; font-weight: 700; cursor: pointer; }
    .del-box .btn-confirm-del { padding: 10px 28px; border-radius: 10px; background: #dc3545; color: #fff; border: none; font-weight: 700; cursor: pointer; box-shadow: 0 4px 12px rgba(220,53,69,0.3); }
</style>

@section Scripts {
    <script>
        function openDel(id, name) {
            document.getElementById('delName').textContent = name;
            document.getElementById('delForm').action = '/Employee/Delete/' + id;
            document.getElementById('delModal').classList.add('active');
        }
        function closeDel() {
            document.getElementById('delModal').classList.remove('active');
        }
    </script>
}