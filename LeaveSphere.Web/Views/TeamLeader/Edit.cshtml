@model LeaveSphere.Web.Models.ViewModels.TeamLeaderViewModel
@{
    Layout = "_Layout";
    ViewData["BodyClass"] = "admin-inner-bg";
    var departments = ViewBag.Departments as List<SelectListItem>;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="glass-item mt-5">
            <h2 class="text-center mb-4"><i class="fas fa-user-edit mr-2"></i> Edit Team Leader</h2>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle mr-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="TeamLeaderId" />

                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label font-weight-bold"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter Full Name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label font-weight-bold"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter Email Address" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Password" class="form-label font-weight-bold">New Password (leave blank to keep current)</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter New Password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="DepartmentId" class="form-label font-weight-bold">Assigned Department</label>
                    <select asp-for="DepartmentId" class="form-control" asp-items="departments">
                        <option value="">-- Select Department --</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>

            <div class="text-center mt-3">
                <a href="/TeamLeader" class="btn btn-link text-white shadow-none">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>
