@model dynamic
@{
    ViewData["Title"] = "My Profile";
    Layout = "_Layout";
    ViewData["BodyClass"] = "admin-bg";
    string role = Model?.Role ?? "User";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-card premium-shadow overflow-hidden">
                <!-- Header Section -->
                <div class="p-5 text-center border-bottom border-white-10 position-relative">
                    <div class="profile-avatar-large mx-auto mb-4">
                        <img src="/images/profile.jpeg" alt="Profile" class="rounded-circle shadow-lg" style="width: 150px; height: 150px; object-fit: cover; border: 4px solid rgba(255,255,255,0.1);">
                    </div>
                    <h1 class="display-6 fw-bold mb-1">@Model?.Name</h1>
                    <span class="badge rounded-pill bg-info px-4 py-2 text-uppercase tracking-wider">@role</span>
                </div>

                <!-- Info Section -->
                <div class="p-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="info-group">
                                <label class="text-white-50 small text-uppercase fw-bold mb-2 d-block">Email Address</label>
                                <div class="h5 mb-0"><i class="fas fa-envelope me-2 text-info"></i>@Model?.Email</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-group">
                                <label class="text-white-50 small text-uppercase fw-bold mb-2 d-block">Department</label>
                                <div class="h5 mb-0"><i class="fas fa-building me-2 text-info"></i>@Model?.DepartmentName</div>
                            </div>
                        </div>

                        @if (role == "Employee")
                        {
                            <div class="col-md-6">
                                <div class="info-group">
                                    <label class="text-white-50 small text-uppercase fw-bold mb-2 d-block">Team Leader</label>
                                    <div class="h5 mb-0"><i class="fas fa-user-tie me-2 text-info"></i>@Model?.TeamLeaderName</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (Model?.LeaveBalance != null && role != "Admin")
                {
                    <div class="p-5 bg-white-5 border-top border-white-10">
                        <h4 class="mb-4">Leave Balance Status</h4>
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="text-center p-3 rounded-4 bg-primary-saas-dim">
                                    <div class="h3 mb-0">@Model.LeaveBalance.totalLeaves</div>
                                    <div class="small text-white-50">Total Entitlement</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-center p-3 rounded-4 bg-warning-saas-dim">
                                    <div class="h3 mb-0">@Model.LeaveBalance.usedLeaves</div>
                                    <div class="small text-white-50">Used Leaves</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-center p-3 rounded-4 bg-success-saas-dim text-success">
                                    <div class="h3 mb-0">@Model.LeaveBalance.remainingLeaves</div>
                                    <div class="small text-white-50">Remaining</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .bg-white-5 { background: rgba(255, 255, 255, 0.05); }
    .border-white-10 { border-color: rgba(255, 255, 255, 0.1) !important; }
    .bg-primary-saas-dim { background: rgba(13, 110, 253, 0.1); }
    .bg-warning-saas-dim { background: rgba(255, 193, 7, 0.1); }
    .bg-success-saas-dim { background: rgba(25, 135, 84, 0.1); }
    .tracking-wider { letter-spacing: 0.1rem; }
</style>
