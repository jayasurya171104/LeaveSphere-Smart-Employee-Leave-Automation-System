@model LeaveSphere.Web.Models.ViewModels.DashboardViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";
    ViewData["BodyClass"] = "admin-bg";
}

<div class="dashboard-header mb-5">
    <h1 class="dashboard-title">My Dashboard</h1>
    <p class="text-secondary small">Comprehensive management of leave requests, employees, and departments.</p>
</div>

<div class="row g-4 mt-3">
    <div class="col-md-4">
        <a href="/Leave/Approve?status=Pending" class="clickable-card h-100">
            <div class="glass-item text-center p-4">
                <h5 class="text-secondary small">Pending Leaves</h5>
                <h2 class="display-6 fw-bold text-warning">@Model.Pending</h2>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Leave/Approve?status=Approved" class="clickable-card h-100">
            <div class="glass-item text-center p-4">
                <h5 class="text-secondary small">Approved Leaves</h5>
                <h2 class="display-6 fw-bold text-success">@Model.Approved</h2>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Leave/Approve?status=Rejected" class="clickable-card h-100">
            <div class="glass-item text-center p-4">
                <h5 class="text-secondary small">Rejected Leaves</h5>
                <h2 class="display-6 fw-bold text-danger">@Model.Rejected</h2>
            </div>
        </a>
    </div>
</div>

<div class="row g-4 mt-5">
    <!-- Approve Leaves Card -->
    <div class="col-md-3">
        <a href="/Leave/Approve" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-warning-saas-dim text-warning">
                    <i class="fas fa-check-circle fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Approve Leaves</h4>
                <p class="text-secondary small mb-0">Pending requests</p>
            </div>
        </a>
    </div>

    <!-- Employee Report Card -->
    <div class="col-md-3">
        <a href="/Leave/EmployeeReport" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-primary-saas-dim text-primary">
                    <i class="fas fa-file-invoice fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Employee Report</h4>
                <p class="text-secondary small mb-0">Detailed status</p>
            </div>
        </a>
    </div>

    <!-- Team Leader Report Card -->
    <div class="col-md-3">
        <a href="/Leave/TeamLeaderReport" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-secondary-saas-dim text-secondary">
                    <i class="fas fa-file-contract fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Team Leader Report</h4>
                <p class="text-secondary small mb-0">Management status</p>
            </div>
        </a>
    </div>

    <!-- Leave Calendar Card -->
    <div class="col-md-3">
        <a href="/Leave/Calendar" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-success-saas-dim text-success">
                    <i class="fas fa-calendar-alt fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Leave Calendar</h4>
                <p class="text-secondary small mb-0">System-wide view</p>
            </div>
        </a>
    </div>

    <!-- Employees Card -->
    <div class="col-md-3">
        <a href="/Employee" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-info-saas-dim text-info">
                    <i class="fas fa-users fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Employees</h4>
                <p class="text-secondary small mb-0">Manage all staff</p>
            </div>
        </a>
    </div>

    <!-- Departments Card -->
    <div class="col-md-3">
        <a href="/Department" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-primary-saas-dim text-primary">
                    <i class="fas fa-building fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Departments</h4>
                <p class="text-secondary small mb-0">Organization structure</p>
            </div>
        </a>
    </div>

    <!-- Team Leaders Card -->
    <div class="col-md-3">
        <a href="/TeamLeader" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-danger-saas-dim text-danger">
                    <i class="fas fa-user-shield fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Team Leaders</h4>
                <p class="text-secondary small mb-0">Manage leadership</p>
            </div>
        </a>
    </div>
</div>

<style>
    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .bg-primary-saas-dim { background: rgba(13, 110, 253, 0.1); }
    .bg-warning-saas-dim { background: rgba(255, 193, 7, 0.1); }
    .bg-success-saas-dim { background: rgba(25, 135, 84, 0.1); }
    .bg-info-saas-dim { background: rgba(13, 202, 240, 0.1); }
    .bg-danger-saas-dim { background: rgba(220, 53, 69, 0.1); }
    .bg-secondary-saas-dim { background: rgba(108, 117, 125, 0.1); }
    
    .clickable-card {
        text-decoration: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .clickable-card:hover {
        transform: translateY(-5px);
    }
    .clickable-card:hover .glass-item {
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.2);
    }
</style>