@model LeaveSphere.Web.Models.ViewModels.DashboardViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Team Leader Dashboard";
    ViewData["BodyClass"] = "admin-bg";
}

<div class="dashboard-header mb-5">
    <h1 class="dashboard-title">My Dashboard</h1>
    <p class="text-secondary small">Manage your team and your own leave requests.</p>
</div>

<div class="row g-4 mt-3">
    <div class="col-md-4">
        <a href="/Leave/Approve?status=Pending" class="clickable-card h-100">
            <div class="glass-item text-center p-4">
                <h5 class="text-secondary small">Pending Leaves</h5>
                <h2 class="display-6 fw-bold text-warning">@Model.Pending</h2>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Leave/Approve?status=Approved" class="clickable-card h-100">
            <div class="glass-item text-center p-4">
                <h5 class="text-secondary small">Approved Leaves</h5>
                <h2 class="display-6 fw-bold text-success">@Model.Approved</h2>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Leave/Approve?status=Rejected" class="clickable-card h-100">
            <div class="glass-item text-center p-4">
                <h5 class="text-secondary small">Rejected Leaves</h5>
                <h2 class="display-6 fw-bold text-danger">@Model.Rejected</h2>
            </div>
        </a>
    </div>
</div>

<div class="row g-4 mt-5">
    <!-- Department Employees -->
    <div class="col-md-4">
        <a href="/Employee" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-primary-saas-dim text-primary">
                    <i class="fas fa-users fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Department Employees</h4>
                <p class="text-secondary small mb-0">Manage your team members</p>
            </div>
        </a>
    </div>

    <!-- Department Leaves -->
    <div class="col-md-4">
        <a href="/Leave/DeptLeaves" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-success-saas-dim text-success">
                    <i class="fas fa-building fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Department Leaves</h4>
                <p class="text-secondary small mb-0">View all leaves in your dept</p>
            </div>
        </a>
    </div>

    <!-- Approve Leaves -->
    <div class="col-md-4">
        <a href="/Leave/Approve" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-warning-saas-dim text-warning">
                    <i class="fas fa-check-circle fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Approve Leaves</h4>
                <p class="text-secondary small mb-0">Process pending requests</p>
            </div>
        </a>
    </div>

    <!-- Apply Leave -->
    <div class="col-md-4">
        <a href="/Leave/Apply" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-warning-saas-dim text-warning">
                    <i class="fas fa-paper-plane fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Apply Leave</h4>
                <p class="text-secondary small mb-0">Submit your own request</p>
            </div>
        </a>
    </div>

    <!-- My Leaves -->
    <div class="col-md-4">
        <a href="/Leave/MyLeaves" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-primary-saas-dim text-primary">
                    <i class="fas fa-file-alt fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">My Leaves</h4>
                <p class="text-secondary small mb-0">Your personal leave history</p>
            </div>
        </a>
    </div>

    <!-- Leave Calendar -->
    <div class="col-md-4">
        <a href="/Leave/Calendar" class="clickable-card h-100">
            <div class="glass-item text-center p-4 h-100 d-flex flex-column justify-content-center">
                <div class="icon-circle mx-auto mb-3 bg-success-saas-dim text-success">
                    <i class="fas fa-calendar-alt fa-lg"></i>
                </div>
                <h4 class="fw-bold text-light">Leave Calendar</h4>
                <p class="text-secondary small mb-0">Team availability view</p>
            </div>
        </a>
    </div>
</div>

<style>
    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .bg-primary-saas-dim { background: rgba(13, 110, 253, 0.1); }
    .bg-warning-saas-dim { background: rgba(255, 193, 7, 0.1); }
    .bg-success-saas-dim { background: rgba(25, 135, 84, 0.1); }
    .bg-info-saas-dim { background: rgba(13, 202, 240, 0.1); }
    
    .clickable-card {
        text-decoration: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .clickable-card:hover {
        transform: translateY(-5px);
    }
    .clickable-card:hover .glass-item {
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.2);
    }
</style>
