@model LeaveSphere.Web.Models.ViewModels.DepartmentViewModel

@{
    ViewData["Title"] = "Create Department";
    ViewData["BodyClass"] = "admin-bg";
}

<style>
    
    html {
        background-color: #0f172a !important;
    }

    body.admin-bg {
        background: radial-gradient(circle at 10% 20%, rgba(0, 210, 255, 0.15) 0%, transparent 40%),
                    radial-gradient(circle at 90% 80%, rgba(58, 123, 213, 0.15) 0%, transparent 40%),
                    linear-gradient(rgba(15, 23, 42, 0.6), rgba(15, 23, 42, 0.6)),
                    url('/images/admin-inner-bg.png') no-repeat center center fixed !important;
        background-size: cover !important;
        color: #fff !important;
        min-height: 100vh;
        margin: 0;
    }

    .dept-form-wrap {
        max-width: 520px;
        margin: 40px auto;
        animation: deptFadeIn 0.5s ease forwards;
    }

    .dept-form-box {
        background: rgba(30, 41, 59, 0.45) !important;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    .dept-form-accent {
        height: 6px;
        background: linear-gradient(135deg, #00d2ff, #3a7bd5);
    }

    .dept-form-inner {
        padding: 40px;
    }

    .dept-form-title {
        text-align: center;
        margin-bottom: 30px;
    }

    .dept-form-title .icon-circle {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #00d2ff, #3a7bd5);
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: #fff;
        margin-bottom: 15px;
        box-shadow: 0 8px 25px rgba(0, 210, 255, 0.3);
    }

    .dept-form-title h3 {
        font-size: 1.8rem;
        font-weight: 900;
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0 0 5px;
    }

    .dept-form-title p {
        color: rgba(255, 255, 255, 0.6);
        font-size: 1.05rem;
        font-weight: 500;
        margin: 0;
    }

    .dept-label {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .dept-input {
        width: 100%;
        padding: 15px 20px;
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 14px;
        font-size: 1.05rem;
        color: #fff !important;
        outline: none;
        transition: all 0.3s;
    }

    .dept-input::placeholder {
        color: rgba(255, 255, 255, 0.3);
    }

    .dept-input:focus {
        background: rgba(255, 255, 255, 0.08) !important;
        border-color: rgba(0, 210, 255, 0.5) !important;
        box-shadow: 0 0 0 4px rgba(0, 210, 255, 0.15);
    }

    .dept-submit-btn {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #007bff, #00b4d8);
        border: none;
        border-radius: 14px;
        color: #fff;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 6px 20px rgba(0, 123, 255, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 10px;
    }

    .dept-submit-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0, 123, 255, 0.5);
    }

    .dept-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        margin-top: 25px;
        transition: all 0.25s;
    }

    .dept-back:hover {
        color: #00d2ff;
        transform: translateX(-5px);
    }

    .dept-form-error {
        background: rgba(220, 53, 69, 0.15);
        border: 1px solid rgba(220, 53, 69, 0.3);
        color: #ff6b6b;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 25px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    @@keyframes deptFadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="dept-form-wrap">
    <div class="dept-form-box">
        <div class="dept-form-accent"></div>
        <div class="dept-form-inner">
            <div class="dept-form-title">
                <div class="icon-circle"><i class="fas fa-plus"></i></div>
                <h3>Create Department</h3>
                <p>Add a new department to your organization</p>
            </div>

            @if (ViewBag.Message != null)
            {
                <div class="dept-form-error">
                    <i class="fas fa-exclamation-circle"></i> @ViewBag.Message
                </div>
            }

            <form action="/Department/Create" method="post">
                <div class="mb-4">
                    <label asp-for="DepartmentName" class="dept-label">
                        <i class="fas fa-building me-1"></i> Department Name
                    </label>
                    <input asp-for="DepartmentName" class="dept-input" placeholder="e.g. Human Resources, Engineering..." />
                    <span asp-validation-for="DepartmentName" class="text-danger small mt-1 d-block" style="font-weight:600;"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="dept-submit-btn">
                        <i class="fas fa-save"></i> Save Department
                    </button>
                </div>

                <div class="text-center">
                    <a href="/Department" class="dept-back">
                        <i class="fas fa-arrow-left"></i> Back to Departments
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Handle Back Button Redirection to Dashboard
        (function () {
            window.history.pushState(null, null, window.location.href);
            window.onpopstate = function () {
                window.location.href = '/Dashboard';
            };
        })();
    </script>
    <partial name="_ValidationScriptsPartial" />
}
